---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Tile from '../components/Tile.astro';
import BlogTile from '../components/BlogTile.astro';
import blogs from '../data/blogs.json';

const allCases = await getCollection('cases');

// Sort all cases once: by year (descending) and by priority within each year (ascending)
const sortedCases = allCases.sort((a, b) => {
  const yearDiff = b.data.year - a.data.year;
  if (yearDiff !== 0) return yearDiff;
  return a.data.priority - b.data.priority;
});

// Group cases by year and collect sorted years in one pass
const casesByYear: Record<number, typeof allCases> = {};
const sortedYears: number[] = [];

for (let i = 0; i < sortedCases.length; i++) {
  const caseEntry = sortedCases[i];
  const year = caseEntry.data.year;
  if (!casesByYear[year]) {
    casesByYear[year] = [];
    sortedYears.push(year);
  }
  casesByYear[year].push(caseEntry);
}
---

<Base 
  title="Zhiyuan designed" 
  description="Zhiyuan's selected designs. Passionate and experienced product designer, based in the Netherlands 🇳🇱, helping make a better Internet at Cloudflare."
  isIndex={true}
>
  <h1 class="font-sans font-normal text-lg lg:text-2xl" style="text-wrap: balance;">
    <a href="/about-zhiyuan" class="font-bold">Zhiyuan</a>
    - product manager based in
    <a href="https://www.holland.com/" target="_blank" rel="noopener noreferrer">the Netherlands</a>
    , helping make a better Internet at
    <a href="https://www.cloudflare.com/" target="_blank" rel="noopener noreferrer">Cloudflare</a>.
  </h1>

  <section>
    <div>
      {blogs.map((blog) => (
        <BlogTile 
          url={blog.url}
          title={blog.title}
          date={blog.formattedDate}
          hn={blog.hn}
        />
      ))}
    </div>
  </section>

  <hr class="h-px bg-stone-300 border-0">

  <section>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-y-8">
      {sortedYears.map((year) => (
        <div>
          <h3 class="font-sans font-semibold text-sm text-stone-400 m-0">{year}</h3>
          {casesByYear[year].map((caseEntry) => (
            <Tile 
              url={`/cases/${caseEntry.id.split('/')[0]}/`}
              title={caseEntry.data.title}
              tags={caseEntry.data.tags}
            />
          ))}
        </div>
      ))}
    </div>
  </section>

  <script>
    interface TileCache {
      element: HTMLElement;
      tags: Set<string>;
      buttons: Map<string, HTMLElement>;
      allButtons: HTMLElement[];
    }

    let cachedTiles: TileCache[] = [];

    function initCache() {
      const tiles = document.querySelectorAll('.case-tile');
      cachedTiles = new Array(tiles.length);
      for (let i = 0; i < tiles.length; i++) {
        const element = tiles[i] as HTMLElement;
        const tags = new Set((element.dataset.tags || '').split(',').filter(Boolean));
        const buttonsNodes = element.querySelectorAll('.tag-btn');
        const allButtons = new Array(buttonsNodes.length);
        const buttons = new Map<string, HTMLElement>();
        for (let j = 0; j < buttonsNodes.length; j++) {
          const btn = buttonsNodes[j] as HTMLElement;
          allButtons[j] = btn;
          buttons.set(btn.dataset.tag!, btn);
        }
        cachedTiles[i] = { element, tags, buttons, allButtons };
      }
    }

    function selectTags() {
      if (cachedTiles.length === 0) {
        initCache();
      }

      const tag = window.location.hash.slice(1);
      const isTagPresent = tag.length > 0;

      for (let i = 0, len = cachedTiles.length; i < len; i++) {
        const tile = cachedTiles[i];
        const element = tile.element;
        const tags = tile.tags;
        const buttons = tile.buttons;
        const allButtons = tile.allButtons;

        // Reset all buttons in this tile
        for (let j = 0, blen = allButtons.length; j < blen; j++) {
          const btn = allButtons[j];
          btn.classList.add('border-stone-600', 'text-stone-600');
          btn.classList.remove('border-highlight', 'bg-highlight', 'text-stone-100');
        }

        if (isTagPresent) {
          if (tags.has(tag)) {
            element.classList.remove('opacity-40');
            const btn = buttons.get(tag);
            if (btn) {
              btn.classList.remove('border-stone-600', 'text-stone-600');
              btn.classList.add('border-highlight', 'bg-highlight', 'text-stone-100');
            }
          } else {
            element.classList.add('opacity-40');
          }
        } else {
          element.classList.remove('opacity-40');
        }
      }
    }

    // Optimization: Use DOMContentLoaded for faster interactivity
    document.addEventListener('DOMContentLoaded', () => selectTags());
    window.onhashchange = () => selectTags();

    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const button = target.closest('.tag-btn');
      if (button) {
        const tag = (button as HTMLElement).dataset.tag;
        if (tag) {
          if (tag === window.location.hash.slice(1)) {
            window.location.assign("#");
          } else {
            window.location.assign(`#${tag}`);
          }
        }
      }
    });
  </script>
</Base>
